<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a1a">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 顶部栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#2a1a0a"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="军　棋"
                android:textSize="18sp"
                android:textColor="#FFD700"
                android:fontFamily="serif"
                android:letterSpacing="0.2"/>

            <TextView
                android:id="@+id/tvTurn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="红方回合"
                android:textSize="14sp"
                android:textColor="#E8621A"
                android:fontFamily="serif"
                android:background="@drawable/bg_turn_pill"
                android:paddingHorizontal="14dp"
                android:paddingVertical="4dp"/>
        </LinearLayout>

        <!-- 分数栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="#111111"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="红方吃子" android:textSize="10sp" android:textColor="#888888"/>
                <TextView android:id="@+id/tvRedScore"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="20sp" android:textColor="#E8621A"
                    android:fontFamily="serif"/>
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="VS" android:textSize="12sp" android:textColor="#444444"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="蓝方吃子" android:textSize="10sp" android:textColor="#888888"/>
                <TextView android:id="@+id/tvBlueScore"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="20sp" android:textColor="#2255AA"
                    android:fontFamily="serif"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 棋盘 -->
        <com.junqi.game.ui.BoardView
            android:id="@+id/boardView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- 消息栏 -->
        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:background="#111111"
            android:textColor="#FFD700"
            android:textSize="12sp"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="点击任意棋子翻开"/>

        <!-- 操作按钮栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#222222"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center">

            <Button
                android:id="@+id/btnSurrender"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="认输"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:background="@drawable/btn_action"/>

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="取消"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:background="@drawable/btn_action"/>

            <Button
                android:id="@+id/btnRestart"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="重开"
                android:textColor="#FFD700"
                android:textSize="13sp"
                android:background="@drawable/btn_primary"/>

        </LinearLayout>
    </LinearLayout>

    <!-- 结算面板（叠加在上方） -->
    <FrameLayout
        android:id="@+id/panelResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:gravity="center">

        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_result_panel"
            android:padding="24dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tvResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="红方胜利！"
                android:textSize="26sp"
                android:textColor="#FFD700"
                android:fontFamily="serif"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvResultScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="红方：0 子　蓝方：0 子"
                android:textSize="13sp"
                android:textColor="#AAAAAA"
                android:layout_marginBottom="20dp"/>

            <Button
                android:id="@+id/btnPlayAgain"
                android:layout_width="180dp"
                android:layout_height="46dp"
                android:text="再来一局"
                android:textColor="#FFD700"
                android:textSize="15sp"
                android:fontFamily="serif"
                android:background="@drawable/btn_start"
                android:layout_marginBottom="10dp"/>

            <Button
                android:id="@+id/btnBackMenu"
                android:layout_width="180dp"
                android:layout_height="46dp"
                android:text="返回主菜单"
                android:textColor="#FFD700"
                android:textSize="15sp"
                android:fontFamily="serif"
                android:background="@drawable/btn_menu_dark"/>

        </LinearLayout>
    </FrameLayout>

</FrameLayout>
