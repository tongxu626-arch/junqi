<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a0a0a">

    <!-- 主菜单面板 -->
    <LinearLayout
        android:id="@+id/panelMain"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="军　棋"
            android:textSize="52sp"
            android:textColor="#FFD700"
            android:fontFamily="serif"
            android:letterSpacing="0.2"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="翻棋暗战 · 经典版"
            android:textSize="13sp"
            android:textColor="#99FFD700"
            android:letterSpacing="0.3"
            android:layout_marginBottom="48dp"/>

        <Button
            android:id="@+id/btnVsAI"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:text="单机 vs AI"
            android:textSize="16sp"
            android:textColor="#FFD700"
            android:fontFamily="serif"
            android:letterSpacing="0.2"
            android:backgroundTint="#00000000"
            android:background="@drawable/btn_menu"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnLocalTwo"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:text="本地双人"
            android:textSize="16sp"
            android:textColor="#FFD700"
            android:fontFamily="serif"
            android:letterSpacing="0.2"
            android:background="@drawable/btn_menu"/>

    </LinearLayout>

    <!-- 难度选择面板 -->
    <LinearLayout
        android:id="@+id/panelDiff"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="#1a1a1a">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="#8B1A10"
            android:gravity="center_vertical"
            android:padding="12dp">

            <Button
                android:id="@+id/btnBackFromDiff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← 返回"
                android:textColor="#FFD700"
                android:background="@null"
                android:textSize="14sp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="选择 AI 难度"
                android:textColor="#FFD700"
                android:textSize="16sp"
                android:gravity="center"
                android:fontFamily="serif"/>

            <View android:layout_width="60dp" android:layout_height="1dp"/>
        </LinearLayout>

        <!-- 5个难度按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center">

            <Button android:id="@+id/btnDiff0"
                android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_margin="3dp"
                android:textColor="#FFD700" android:textSize="11sp"
                android:background="@drawable/btn_diff"/>
            <Button android:id="@+id/btnDiff1"
                android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_margin="3dp"
                android:textColor="#FFD700" android:textSize="11sp"
                android:background="@drawable/btn_diff"/>
            <Button android:id="@+id/btnDiff2"
                android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_margin="3dp"
                android:textColor="#FFD700" android:textSize="11sp"
                android:background="@drawable/btn_diff"/>
            <Button android:id="@+id/btnDiff3"
                android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_margin="3dp"
                android:textColor="#FFD700" android:textSize="11sp"
                android:background="@drawable/btn_diff"/>
            <Button android:id="@+id/btnDiff4"
                android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_margin="3dp"
                android:textColor="#FFD700" android:textSize="11sp"
                android:background="@drawable/btn_diff"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvDiffName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textColor="#FFD700"
            android:fontFamily="serif"
            android:gravity="center"
            android:padding="8dp"/>

        <TextView
            android:id="@+id/tvDiffDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:paddingBottom="24dp"/>

        <Button
            android:id="@+id/btnStartGame"
            android:layout_width="200dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:text="开始对战"
            android:textSize="16sp"
            android:textColor="#FFD700"
            android:fontFamily="serif"
            android:letterSpacing="0.2"
            android:background="@drawable/btn_start"/>

    </LinearLayout>

</FrameLayout>
